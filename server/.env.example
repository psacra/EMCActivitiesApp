# Postgres connection string (e.g. from Supabase or Neon free tier)
DATABASE_URL=postgres://user:password@host:5432/dbname

# From https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Public URLs once deployed (used for OAuth redirects)
PUBLIC_SERVER_URL=https://your-backend.onrender.com
PUBLIC_CLIENT_URL=https://your-frontend.onrender.com

# Optional: require this password (sent as header x-curator-password) to edit/curate/delete activities.
# Leave unset during local development if you want open editing.
CURATOR_PASSWORD=change-me

# Where uploaded GPX files are stored on the server's disk
GPX_UPLOAD_DIR=./uploads

PORT=4000
